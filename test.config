worker_processes 1;

events {
    worker_connections 1024;
    use poll;
}

http {
    server {
        listen 8080;
        server_name localhost;
        
        location / {
            root ./www;
            index index.html;
            autoindex on;
        }

        location /upload/ {
            upload_dir ./www/uploads;
        }

        location /cgi-bin/ {
            root ./www;
            cgi_extension .py /usr/bin/python3;
            cgi_extension .sh /bin/bash;
        }
    }
}