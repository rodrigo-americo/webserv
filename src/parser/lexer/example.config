# Comentário global
# Diretiva simples no contexto global
worker_processes 4;
error_log /var/log/nginx/error.log warn;
pid /var/run/nginx.pid;

events {
    worker_connections 1024;
    use poll;
    multi_accept on;
}

http {
    # Diretivas simples
    include       mime.types;
    default_type  application/octet-stream;
    sendfile      on;
    keepalive_timeout 65;

    # Diretiva com múltiplos valores
    index index.html index.htm index.php;

    # Bloco sem argumentos com diretivas aninhadas
    log_format main '$remote_addr - $remote_user [$time_local] '
                    '"$request" $status $body_bytes_sent';

    access_log /var/log/nginx/access.log main;

    # Bloco com 1 argumento
    upstream backend {
        server 127.0.0.1:8080 weight=3;
        server 127.0.0.1:8081;
        server 127.0.0.1:8082 backup;
    }

    # Bloco com 1 argumento (server virtual)
    server {
        listen 8080;
        listen [::]:8080 ipv6only=on;
        server_name example.com www.example.com;

        root /var/www/html;
        autoindex off;
        client_max_body_size 10m;

        # Bloco com 2 argumentos
        location / {
            try_files $uri $uri/ =404;
        }

        # Bloco com modificador + argumento
        location = /favicon.ico {
            log_not_found off;
            access_log off;
        }

        # Bloco aninhado com múltiplos níveis
        location /api {
            proxy_pass <http://backend>;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;

            # Bloco dentro de location
            proxy_cache_bypass $http_upgrade;
        }

        location ~ \\.php$ {
            fastcgi_pass 127.0.0.1:9000;
            fastcgi_index index.php;
            fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
            include fastcgi_params;
        }

        location ~* \\.(jpg|jpeg|png|gif|ico|css|js)$ {
            expires 30d;
            add_header Cache-Control "public, no-transform";
        }

        # Diretiva com valor que contém espaços (entre aspas)
        error_page 404 /404.html;
        error_page 500 502 503 504 /50x.html;

        location = /50x.html {
            root /usr/share/nginx/html;
        }
    }

    # Segundo server — HTTPS
    server {
        listen 443 ssl;
        server_name example.com;

        ssl_certificate     /etc/nginx/ssl/example.crt;
        ssl_certificate_key /etc/nginx/ssl/example.key;
        ssl_protocols       TLSv1.2 TLSv1.3;
        ssl_ciphers         HIGH:!aNULL:!MD5;

        location / {
            root /var/www/secure;
            index index.html;
        }
    }
}
