      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "|P1-B| = sqrt([P1-B].x² + [P1-B].y² + [P1-B].z²);",
      "autoResize": true,
      "lineHeight": 1.25
